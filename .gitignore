# ------------------------------------------------------------
# Stratospheric ozone/UV profile (.gitignore)
#
# This repo includes:
# - Python scripts (using a local venv at ./.venv via ./py and ./pip)
# - libRadtran (vendored) + uvspec runs
# - A loop runner that generates per-altitude inputs/outputs under ./loop
# ------------------------------------------------------------

# -------------------------
# Python / virtualenv
# -------------------------
.venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
.cache/

# Packaging/build artifacts (even if you don't currently build a package)
build/
dist/
*.egg-info/

# -------------------------
# Jupyter / notebooks
# -------------------------
.ipynb_checkpoints/

# -------------------------
# OS / editor
# -------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

.vscode/
.idea/
*.swp
*.swo
*~

# -------------------------
# Logs / temporary
# -------------------------
*.log
*.tmp
*.bak
*.old

# -------------------------
# Data downloads / outputs
# -------------------------
# CAMS netCDF downloads are reproducible via cams_download3.py and can be large.
*.nc

# -------------------------
# libRadtran (do not commit vendored binaries/data; keep empty folder only)
# -------------------------
libRantran/*
!libRantran/.gitkeep

# -------------------------
# UVSPEC loop outputs (generated by run_loop.sh)
# -------------------------
loop/run_*km.inp
loop/eup_*km.dat

# -------------------------
# ltr-390uv-01-response generated debug/overlay images
# -------------------------
ltr-390uv-01-response/als_response_overlay_zoom_axes.png
ltr-390uv-01-response/uv_response_bbox_debug.png
ltr-390uv-01-response/uv_response_overlay_full.png
ltr-390uv-01-response/uv_response_overlay_zoom_axes.png


