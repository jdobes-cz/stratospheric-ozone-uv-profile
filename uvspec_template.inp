# ---- data path ----
data_files_path libRantran/libRadtran-2.0.6/data

# ---- location & time (UTC) ----
latitude N 50.798056
longitude E 4.357500
time 2026 04 23 12 00 00

# ---- atmosphere baseline ----
atmosphere_file midlatitude_summer

# ---- overwrite ozone profile ----
mol_file O3 o3_mmr.dat mmr

# ---- radiative transfer setup ----
rte_solver disort
number_of_streams 8
pseudospherical

# ---- spectral settings ----
mol_abs_param crs
source solar /mnt/c/Users/jdobe/Downloads/Stratospheric_baloon/stratospheric-ozone-uv-profile/libRantran/libRadtran-2.0.6/data/solar_flux/kurudz_0.1nm.dat
wavelength 250 1100
spline 250 1100 1

# ---- surface ----
# Belgian late-spring land surface, CLEAR-SKY day (Open-Meteo confirms 0%
# cloud cover throughout 2026-04-23 in Brussels with peak shortwave 821 W/m^2
# at 14:00 local). Without clouds, the upward-facing sensor footprint sees
# only the underlying mixed land (vegetation, cropland, urban) with a typical
# springtime albedo of ~0.15. See Experiment/data_review.md §2.4.
albedo 0.15

# ---- output altitude ----
zout_sea 0

# ---- output columns ----
output_user lambda sza zout eup edir edn eglo
quiet
